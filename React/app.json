{
  "expo": {
    "name": "ReactVsFlutterRN",
    "slug": "react-vs-flutter-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reactvsflutterrn",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.reactvsflutterrn"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.reactvsflutterrn"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
